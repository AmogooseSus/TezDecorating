---
import { Image } from "astro:assets";
import logo from "../../public/Tez_Decor.svg";
---

<header
  class="flex items-center gap-2
  md:gap-0 md:flex-row flex-col
  md:items-center md:justify-around
  text-base sm:text-lg sticky
  top-0 md:text-lg
  lg:text-xl w-screen bg-gray-50 bg-opacity-50 p-4 md:p-5 z-10"
>
  <div class="flex md:gap-2 gap-1 items-center">
    <Image src={logo} loading="eager" alt="Tez Decor Logo" class="-auto w-14" />
    <h1 class="font-[Grown] text-2xl md:text-2xl font-semibold">Tez Decor</h1>
  </div>
  <nav class="flex md:gap-10 justify-around md:w-auto w-full pt-4 md:pt-0">
    <a
      href="#hero"
      class="md:hover:text-gray-400 md:bg-gray-50 bg-gray-700 md:text-black text-white rounded-sm px-2 py-1 md:p-0 md:hover:bg-gray-50 hover:bg-gray-600"
      >Home</a
    >
    <!-- <a
      href="#about"
      class="md:hover:text-gray-400 md:bg-gray-50 bg-gray-700 md:text-black text-white rounded-sm px-2 py-1 md:p-0 md:hover:bg-gray-50 hover:bg-gray-600"
      >About</a
    > -->
    <a
      href="#services"
      class="md:hover:text-gray-400 md:bg-gray-50 bg-gray-700 md:text-black text-white rounded-sm px-2 py-1 md:p-0 md:hover:bg-gray-50 hover:bg-gray-600"
      >Services</a
    >
    <a
      href="#gallery"
      class="md:hover:text-gray-400 md:bg-gray-50 bg-gray-700 md:text-black text-white rounded-sm px-2 py-1 md:p-0 md:hover:bg-gray-50 hover:bg-gray-600"
      >Gallery</a
    >
    <a
      href="#contact"
      class="md:hover:text-gray-400 md:bg-gray-50 bg-gray-700 md:text-black text-white rounded-sm px-2 py-1 md:p-0 md:hover:bg-gray-50 hover:bg-gray-600"
      >Contact</a
    >
  </nav>
</header>
