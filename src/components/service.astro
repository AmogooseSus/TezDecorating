---
const { imageUrl, title, description } = Astro.props;

import { Image } from 'astro:assets';
---

<div class="flex flex-col items-start p-6 gap-4">
  <Image src={imageUrl} class="w-full md:w-1240 h-96 rounded-lg object-cover" alt={title} loading="lazy" />
  <h2 class="text-xl font-bold text-gray-800">{title}</h2>
  <h3 class="text-gray-600">{description}</h3>
</div>
